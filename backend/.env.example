GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional — AI features (free at aistudio.google.com)
GEMINI_API_KEY=AIza...

# Optional — Yandex Maps (free at developer.tech.yandex.ru)
VITE_YANDEX_MAPS_API_KEY=your-key-here
